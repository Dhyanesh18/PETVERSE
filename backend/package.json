{
    "name": "petverse",
    "version": "1.0.0",
    "type": "commonjs",
    "description": "Your one-stop destination for all pet needs",
    "main": "src/server.js",
    "scripts": {
        "start": "node src/app.js",
        "dev": "nodemon src/app.js",
        "test": "jest --testEnvironment=node --forceExit",
        "test:coverage": "jest --coverage --testEnvironment=node --forceExit",
        "test:report": "jest --coverage --json --outputFile=coverage/test-results.json --testEnvironment=node --forceExit && echo Test report written to coverage/test-results.json — HTML report at coverage/lcov-report/index.html",
        "benchmark": "node src/scripts/redis-benchmark.js",
        "ts:index": "node src/scripts/typesense-index.js",
        "create:test-user": "node src/scripts/create-test-user.js",
        "test:email": "node src/scripts/test-email.js"
    },
    "dependencies": {
        "bcrypt": "^5.1.1",
        "bcryptjs": "^3.0.2",
        "body-parser": "^1.20.3",
        "cloudinary": "^2.9.0",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "csurf": "^1.11.0",
        "dotenv": "^16.5.0",
        "ejs": "^3.1.9",
        "express": "^4.18.2",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^8.2.1",
        "express-session": "^1.18.1",
        "express-validator": "^7.3.1",
        "helmet": "^8.1.0",
        "ioredis": "^5.10.1",
        "jest": "^30.3.0",
        "joi": "^17.13.3",
        "mongoose": "^8.13.2",
        "morgan": "^1.10.1",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^7.0.13",
        "razorpay": "^2.9.6",
        "rotating-file-stream": "^3.2.8",
        "socket.io": "^4.8.1",
        "sqlite3": "^5.1.7",
        "supertest": "^7.2.2",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "typesense": "^1.8.2"
    },
    "devDependencies": {
        "nodemon": "^3.1.10"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/src/__tests__/**/*.test.js"
        ],
        "setupFiles": [
            "./src/__tests__/setup.js"
        ],
        "coverageDirectory": "coverage",
        "collectCoverageFrom": [
            "src/**/*.js",
            "!src/scripts/**",
            "!src/docs/**"
        ],
        "coverageReporters": [
            "text",
            "lcov",
            "html",
            "json-summary"
        ],
        "testTimeout": 15000
    }
}
