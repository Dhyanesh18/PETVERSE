# Docker Compose variable substitution file
# This file is read by docker-compose.yml for ${VARIABLE} substitution.
# It is NOT the backend app config (that is backend/.env).
#
# The TYPESENSE_API_KEY here must match backend/.env TYPESENSE_API_KEY
# so the Typesense container and the backend agree on the same key.
TYPESENSE_API_KEY=a3f8c2e1b9d4e7f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4
